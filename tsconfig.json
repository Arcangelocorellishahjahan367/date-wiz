{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  }
}
